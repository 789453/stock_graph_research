# ==================================================
# 1. a_share_semantic_dataset 严格规则
# 只允许 npy 子目录下的 json 文件，其余全部禁止
# ==================================================
/a_share_semantic_dataset/**
!/a_share_semantic_dataset/npy/
/a_share_semantic_dataset/npy/**
!/a_share_semantic_dataset/npy/*/*.json

# ==================================================
# 2. cache 目录：只允许 json/yaml/md，保留文件夹结构
# ==================================================
/cache/**
!/cache/**/
!/cache/**/*.json
!/cache/**/*.yaml
!/cache/**/*.yml
!/cache/**/*.md

# ==================================================
# 3. outputs 目录：只允许 md/yaml/json/png/log
# ==================================================
/outputs/**
!/outputs/**/
!/outputs/**/*.md
!/outputs/**/*.yaml
!/outputs/**/*.yml
!/outputs/**/*.json
!/outputs/**/*.png
!/outputs/**/*.log

# ==================================================
# 4. 全局禁止：大数据/数据库文件
# ==================================================
*.parquet
*.duckdb
*.db
*.sqlite
*.csv

# ==================================================
# 5. 全局允许：所有 md 文件
# ==================================================
!*.md

# ==================================================
# 6. 通用忽略（Python/系统缓存）
# ==================================================

# 只忽略这两个提交脚本，其他所有 sh / log 全部上传！
/scripts/git_push_to_main.sh
/scripts/git_update_main.sh


__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/
*.egg-info/
*.egg
*.whl
*.so
*.dylib
.DS_Store
.idea/
.vscode/